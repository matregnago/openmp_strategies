{
  "languages": {
    "R": {
      "language_servers": ["r_language_server"],
    },
    "C": {
      "language_servers": ["clangd"],
    },
  },
  "lsp": {
    "r_language_server": {
      "binary": {
        "path": "direnv",
        "arguments": [
          "exec",
          ".",
          "R",
          "--slave",
          "-e",
          "languageserver::run()",
        ],
      },
    },
    "clangd": {
      "binary": {
        "path": "direnv",
        "arguments": ["exec", ".", "clangd"],
      },
    },
  },
}
